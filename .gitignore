# ========================================
# Principia Cognitia: .gitignore
# ========================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Virtual Environments ---
venv/
ENV/
env/
.venv

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Logs (игнорируем все экспериментальные логи) ---
logs/
*.log
*.csv
*.npz
*.json
!logs/.gitkeep

# --- Figures (генерируемые, не коммитим) ---
figures/
*.png
*.jpg
*.jpeg
*.svg
*.pdf
!docs/figures/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Temporary ---
tmp/
temp/
*.tmp
*.bak

# --- Secrets ---
.env
*.key
*.pem